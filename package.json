{
  "name": "swc-plugin-react-intl-auto",
  "version": "1.0.0",
  "description": "SWC plugin for React Intl Auto - automatically adds IDs to FormattedMessage, defineMessages, and formatMessage calls",
  "main": "index.js",
  "scripts": {
    "build": "node build.js",
    "build:wasm32": "cargo build --release --target wasm32-unknown-unknown",
    "build:wasip1": "cargo build --release --target wasm32-wasip1",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "swc",
    "plugin",
    "react-intl",
    "i18n",
    "internationalization",
    "babel-plugin"
  ],
  "author": "Your Name",
  "license": "MIT",
