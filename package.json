    "swc-plugin-react-intl-auto.wasm",
    "index.js",
    "README.md"
  ],
  "devDependencies": {
    "@swc/core": "^1.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "typescript": "^5.0.0",
    "ts-jest": "^29.0.0",
    "string-snapshot-serializer": "1.0.1"
  },
  "peerDependencies": {
    "@swc/core": "^1.0.0"
  }
}