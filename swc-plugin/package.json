{
  "name": "swc-plugin-react-intl-auto",
  "version": "0.1.0",
  "description": "SWC plugin for automatic react-intl ID management",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "swc_plugin_react_intl_auto.wasm"
  ],
  "scripts": {
