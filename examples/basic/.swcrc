{
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "tsx": true,
            "decorators": true
        },
        "transform": {
            "react": {
                "runtime": "automatic"
            }
        },
        "experimental": {
            "plugins": [["./swc-plugin-react-intl-auto-fs.wasm", {}]]
        }
    },
    "module": {
        "type": "es6"
    }
}
