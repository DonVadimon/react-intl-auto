  },
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "@swc/core": "^1.3.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.1.0",
    "wasm-pack": "^0.12.0"
  }
}
