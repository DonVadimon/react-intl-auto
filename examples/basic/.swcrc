{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "decorators": true
    },
    "transform": {
      "react": {
        "runtime": "automatic"
      }
    },
    "experimental": {
      "plugins": [
        [
          "/Users/ryan/mine/swc-plugin-react-intl-auto/swc-plugin-react-intl-auto.wasm",
          // "swc-plugin-react-intl-auto",
          {
            "removePrefix": "src/messages",
            "separator": ".",
            "filebase": false,
            "extractComments": true
          }
        ]
      ]
    }
  },
  "module": {
    "type": "es6"
  }
}